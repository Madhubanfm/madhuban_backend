        {
          "name": "Attendance",
          "description": "`GET /api/staff/attendance` — optional `date` (YYYY-MM-DD), IST calendar day. `POST /api/staff/attendance` — multipart: `action` check_in | check_out, `latitude`, `longitude`; check-in also requires `selfie` (jpeg/png). Set `attendanceSelfiePath` in environment to a local image path for check-in.",
          "item": [
            {
              "name": "GET Staff - Attendance (today)",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{token}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/staff/attendance",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "staff", "attendance"]
                },
                "description": "Returns `phase`: NOT_CHECKED_IN | ACTIVE | COMPLETED, check-in/out times, GPS, `shift` (MORNING | EVENING | NIGHT)."
              },
              "response": []
            },
            {
              "name": "GET Staff - Attendance (by date)",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{token}}"
                  }
                ],
                "url": {
                  "raw": "{{baseUrl}}/api/staff/attendance?date={{taskDate}}",
                  "host": ["{{baseUrl}}"],
                  "path": ["api", "staff", "attendance"],
                  "query": [
                    {
                      "key": "date",
                      "value": "{{taskDate}}"
                    }
                  ]
                },
                "description": "Same as today but for `taskDate` (YYYY-MM-DD)."
              },
              "response": []
            },
            {
              "name": "POST Staff - Attendance check-in (multipart)",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{token}}"
                  }
                ],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    {
                      "key": "action",
                      "value": "check_in",
                      "type": "text",
                      "description": "Required"
                    },
