            {
              "name": "Get Property Floors",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/properties/{{propertyId}}/floors",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "properties",
                    "{{propertyId}}",
                    "floors"
                  ]
                },
                "description": "Floors for a property (PropertyFloor rows). Use `id` as `propertyFloorId` for zones."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "let data = {};",
                      "try { data = pm.response.json(); } catch (e) {}",
                      "if (data.data && data.data[0] && data.data[0].id) {",
                      "  pm.environment.set(\"propertyFloorId\", String(data.data[0].id));",
                      "}"
                    ]
                  }
                }
              ],
              "response": []
            },
            {
              "name": "Get Property Zones for Floor",
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "{{baseUrl}}/api/properties/{{propertyId}}/floors/{{propertyFloorId}}/zones",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "properties",
                    "{{propertyId}}",
                    "floors",
                    "{{propertyFloorId}}",
                    "zones"
                  ]
                },
                "description": "Zones (PropertyFloorZone) for one floor. `id` here is the **zoneId** for POST /api/tasks."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "let data = {};",
