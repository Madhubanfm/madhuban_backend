        {
          "name": "Write",
          "item": [
            {
              "name": "Create Property (JSON)",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"propertyName\": \"Skyline Heights\",\n  \"floors\": [\n    {\n      \"floorNumber\": 1,\n      \"zones\": [\n        { \"name\": \"Zone A\" },\n        { \"name\": \"Zone B\" },\n        { \"name\": \"Zone C\" }\n      ]\n    },\n    {\n      \"floorNumber\": 2,\n      \"zones\": [\n        { \"name\": \"Zone A\" }\n      ]\n    },\n    {\n      \"floorNumber\": 3,\n      \"zones\": [\n        { \"name\": \"Zone C\" }\n      ]\n    }\n  ]\n}"
                },
                "url": {
                  "raw": "{{baseUrl}}/api/properties",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "properties"
                  ]
                },
                "description": "JSON body. Creates the property and nested floors/zones in one transaction. For multipart + optional image file, use **Properties - Create (form-data)**. `name` is an alias for `propertyName`."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "let data = {};",
                      "try {",
                      "  data = pm.response.json();",
                      "} catch (e) {}",
                      "",
                      "if (data.data && data.data.id) {",
                      "  pm.environment.set(\"propertyId\", String(data.data.id));",
                      "}"
                    ]
                  }
                }
              ],
              "response": []
            },
            {
              "name": "Create Property (form-data, optional image)",
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    {
                      "key": "propertyName",
                      "value": "Skyline Heights",
                      "type": "text",
                      "description": "Required"
                    },
                    {
                      "key": "floors",
                      "value": "[{\"floorNumber\":1,\"zones\":[{\"name\":\"Zone A\"}]}]",
                      "type": "text",
                      "description": "Optional JSON array string"
                    },
                    {
                      "key": "image",
                      "type": "file",
                      "src": [],
                      "description": "Optional: jpeg, png, gif, webp (max 5MB). Choose file in Postman."
                    }
                  ]
                },
                "url": {
                  "raw": "{{baseUrl}}/api/properties",
                  "host": [
                    "{{baseUrl}}"
                  ],
                  "path": [
                    "api",
                    "properties"
                  ]
                },
                "description": "Same as JSON create but uses multipart/form-data. Do not set Content-Type manually (Postman adds boundary). Response includes `imageUrl` path under `/uploads/properties/...` when a file is sent."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "let data = {};",
                      "try {",
                      "  data = pm.response.json();",
                      "} catch (e) {}",
                      "",
                      "if (data.data && data.data.id) {",
                      "  pm.environment.set(\"propertyId\", String(data.data.id));",
                      "}"
                    ]
                  }
                }
              ],
              "response": []
            },
