{
  "info": {
    "_postman_id": "f9c34fd3-5a7c-4ba4-9e72-2c4c8e5ea101",
    "name": "Madhuban Backend API",
    "description": "Postman collection for Madhuban role-based task backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "let data = {};",
              "try {",
              "  data = pm.response.json();",
              "} catch (e) {}",
              "",
              "if (data.token) {",
              "  pm.environment.set(\"token\", data.token);",
              "}",
              "",
              "if (data.user && data.user.id) {",
              "  pm.environment.set(\"adminUserId\", String(data.user.id));",
              "}"
            ]
          }
        }
      ],
      "response": []
    },
