DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB_NAME?sslmode=require"
JWT_SECRET="replace-with-a-strong-secret"
# 32-byte AES-256 key used for encrypting *recoverable* passwords (see lib/password-encryption.ts)
# Recommended format: base64 (32 random bytes).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PASSWORD_ENCRYPTION_KEY="REPLACE_WITH_BASE64_32_BYTES"

# CORS
# Comma-separated list of allowed frontend origins (e.g. "http://localhost:5173,https://app.example.com")
# If omitted, all origins are allowed.
CORS_ORIGIN_ALLOWLIST=""
# Set to "true" if your frontend sends cookies/credentials (axios `withCredentials`, fetch `credentials: 'include'`).
CORS_ALLOW_CREDENTIALS="false"

# AWS S3 (task photos)
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="your-bucket-name"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
