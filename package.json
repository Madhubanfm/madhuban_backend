{
  "name": "madhuban-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "db:fix-master-task-sequence": "prisma db execute --schema prisma/schema.prisma --file prisma/sql/fix_master_task_id_sequence.sql",
    "db:setup": "npm run prisma:generate && npm run prisma:migrate -- --name init && npm run prisma:seed",
    "cron:run": "tsx scripts/run-daily-task-cron.ts",
    "zones:import:excel": "tsx scripts/import-zones-from-excel.ts",
    "tasks:import:excel": "tsx scripts/import-master-tasks-from-excel.ts",
    "sync:neon-to-rds": "tsx scripts/sync-neon-to-rds.ts",
    "db:clear": "tsx scripts/clear-rds-database.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6",
    "next": "15.2.4",
    "node-cron": "^4.0.7",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.11",
    "@types/node-cron": "^3.0.11",
    "@types/react": "19.2.14",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
